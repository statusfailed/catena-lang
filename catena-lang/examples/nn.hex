# Log approximation for positive, normalized f32 inputs.
# Decompose x by bit manipulation into
#   x = m * 2^e
# with m in [0.5, 1), then approximate:
#   log(x) ~= poly(m) + e * ln(2)

(def program log-approx : (f32 val) -> (f32 val) =
  {[x.]
    (const.u32.0x007FFFFF [frac_mask.])
    (const.u32.0x00000017 [exp_shift.])
    (const.u32.0x3F000000 [half_bits.])
    (const.u32.0x0000007E [mantissa_bias.])
    (const.u32.0x3F317218 u32.bitcast-f32 [ln2.])
    (const.u32.0xC00BE629 u32.bitcast-f32 [c0.])
    (const.u32.0x4087355A u32.bitcast-f32 [c1.])
    (const.u32.0xC03AA687 u32.bitcast-f32 [c2.])
    (const.u32.0x3F60A4E1 u32.bitcast-f32 [c3.])

    ([.x] f32.bitcast-u32 [x_bits.])
    ([.x_bits exp_shift] u32.shr [exp_bits.])
    ([.x_bits frac_mask] u32.and [frac_bits.])

    ([.frac_bits half_bits] u32.add [m_bits.])
    ([.m_bits] u32.bitcast-f32 [m.])

    ([.exp_bits] u32.to-f32 [biased_exp_f.])
    ([.mantissa_bias] u32.to-f32 [mantissa_bias_f.])
    ([.biased_exp_f mantissa_bias_f] f32.sub [e.])

    ([.m c3] f32.mul [p3.])
    ([.c2 p3] f32.add [p2.])
    ([.m p2] f32.mul [m_p2.])
    ([.c1 m_p2] f32.add [p1.])
    ([.m p1] f32.mul [m_p1.])
    ([.c0 m_p1] f32.add [poly.])

    ([.e ln2] f32.mul [elog2.])
    ([.poly elog2] f32.add [result.])
    [.result]
  }
)

# Range-reduced exp approximation using split ln(2) constants and
# a degree-3 minimax polynomial on the reduced interval.
(def program exp-approx-nonneg : (f32 val) -> (f32 val) =
  {[x.]
    (const.u32.0x3FB8AA3B u32.bitcast-f32 [inv_ln2.])
    (const.u32.0x3F317200 u32.bitcast-f32 [ln2_hi.])
    (const.u32.0x35BFBE8E u32.bitcast-f32 [ln2_lo.])
    (const.u32.0x3F7FF8FC u32.bitcast-f32 [c0.])
    (const.u32.0x3F809C7E u32.bitcast-f32 [c1.])
    (const.u32.0x3EEF1187 u32.bitcast-f32 [c2.])
    (const.u32.0x3E738A8B u32.bitcast-f32 [c3.])

    ([.x inv_ln2] f32.mul [scaled.])
    ([.scaled] f32.round-to-u32 [k_u32.])
    ([.k_u32] u32.to-f32 [k_f32.])

    ([.k_f32 ln2_hi] f32.mul [k_ln2_hi.])
    ([.k_f32 ln2_lo] f32.mul [k_ln2_lo.])
    ([.x k_ln2_hi] f32.sub [r1.])
    ([.r1 k_ln2_lo] f32.sub [xr.])

    ([.xr c3] f32.mul [xr_c3.])
    ([.c2 xr_c3] f32.add [p2.])
    ([.xr p2] f32.mul [xr_p2.])
    ([.c1 xr_p2] f32.add [p1.])
    ([.xr p1] f32.mul [xr_p1.])
    ([.c0 xr_p1] f32.add [poly.])

    (const.u32.0x0000007F [bias_u32.])
    (const.u32.0x00800000 [exp_step_u32.])
    ([.k_u32 bias_u32] u32.add [biased_exp.])
    ([.biased_exp exp_step_u32] u32.mul [pow2_bits.])
    ([.pow2_bits] u32.bitcast-f32 [pow2k.])

    ([.poly pow2k] f32.mul [result.])
    [.result]
  }
)

(def program exp-approx : (f32 val) -> (f32 val) =
  {[x.]
    (const.u32.0x00000000 u32.to-f32 [zero.])
    (const.u32.0x3F800000 u32.bitcast-f32 [one.])

    ([.x] f32.neg [neg_x.])
    ([.x zero] f32.lt [is_negative.])
    ([.is_negative neg_x x] f32.select [magnitude.])

    ([.magnitude] exp-approx-nonneg [base.])
    ([.one base] f32.div [reciprocal.])
    ([.is_negative reciprocal base] f32.select [result.])
    [.result]
  }
)

# sqrt(x) by Newton-Raphson iteration
# guess{n+1} = 0.5 * (guess{n} + x / guess{n})
(def program sqrt : (f32 val) -> (f32 val) =
  {[x.]
    (const.u32.0x00000000 u32.to-f32 [zero.])
    (const.u32.0x3F800000 u32.bitcast-f32 [one.])
    (const.u32.0x3F000000 u32.bitcast-f32 [half.])

    ([.x one] f32.lt [lt_one.])
    ([.lt_one one x] f32.select [guess0.])

    ([.x guess0] f32.div [ratio0.])
    ([.guess0 ratio0] f32.add [sum0.])
    ([.sum0 half] f32.mul [guess1.])

    ([.x guess1] f32.div [ratio1.])
    ([.guess1 ratio1] f32.add [sum1.])
    ([.sum1 half] f32.mul [guess2.])

    ([.x guess2] f32.div [ratio2.])
    ([.guess2 ratio2] f32.add [sum2.])
    ([.sum2 half] f32.mul [guess3.])

    ([.x guess3] f32.div [ratio3.])
    ([.guess3 ratio3] f32.add [sum3.])
    ([.sum3 half] f32.mul [guess4.])

    ([.x guess4] f32.div [ratio4.])
    ([.guess4 ratio4] f32.add [sum4.])
    ([.sum4 half] f32.mul [guess5.])

    ([.x guess5] f32.div [ratio5.])
    ([.guess5 ratio5] f32.add [sum5.])
    ([.sum5 half] f32.mul [guess6.])

    ([.x zero] f32.lte [is_nonpositive.])
    ([.is_nonpositive zero guess6] f32.select [result.])
    [.result]
  }
)

# sigmoid(x) = 1 / (1 + exp(-x))
(def program sigmoid : (f32 val) -> (f32 val) =
  {[x.]
    (f32.one [one.])

    ([.x] f32.neg [neg_x.])
    ([.neg_x] exp-approx [exp_neg_x.])
    ([.one exp_neg_x] f32.add [denominator.])
    ([.one denominator] f32.div [result.])
    [.result]
  }
)

# silu(x) = x * sigmoid(x)
(def program silu : (f32 val) -> (f32 val) =
  {[x.]
    ([.x] sigmoid [gate.])
    ([.x gate] f32.mul [result.])
    [.result]
  }
)

# tanh(x) = 2 * sigmoid(2x) - 1
(def program tanh : (f32 val) -> (f32 val) =
  {[x.]
    (f32.one [one.])
    (const.u32.0x40000000 u32.bitcast-f32 [two.])

    ([.x two] f32.mul [twice_x.])
    ([.twice_x] sigmoid [sigma.])
    ([.sigma two] f32.mul [twice_sigma.])
    ([.twice_sigma one] f32.sub [result.])
    [.result]
  }
)

# approx GELU(x) ≈ 0.5 * x * (1 + tanh(sqrt(2/pi) * (x + 0.044715 * x^3)))
(def program gelu-approx : (f32 val) -> (f32 val) =
  {[x.]
    (f32.one [one.])
    (const.u32.0x3F000000 u32.bitcast-f32 [half.])
    (const.u32.0x3F4C422A u32.bitcast-f32 [sqrt_2_over_pi.])
    (const.u32.0x3D372713 u32.bitcast-f32 [cubic_coeff.])

    ([.x x] f32.mul [x2.])
    ([.x2 x] f32.mul [x3.])
    ([.x3 cubic_coeff] f32.mul [cubic_term.])
    ([.x cubic_term] f32.add [inner.])
    ([.inner sqrt_2_over_pi] f32.mul [scaled.])
    ([.scaled] tanh [shaped.])
    ([.one shaped] f32.add [gate.])
    ([.x gate] f32.mul [gated_x.])
    ([.gated_x half] f32.mul [result.])
    [.result]
  }
)
