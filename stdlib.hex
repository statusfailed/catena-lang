################################################################################
# Propositional logic

(object |- : 1 -> 1)  # provability
(object -> : 2 -> 1)  # implication

(object eq : 2 -> 1)  # equality
(object not : 1 -> 1) # negation

# TODO
# (Con/Dis)junction
#(object and : 2 -> 1)
#(object or  : 2 -> 1)

################################################################################
# Syntax

# Array types and runtime values
(object extent : 1 -> 1) # extent(n):   array size n
(object index : 1 -> 1)  # index(e):    array indices into arrays with extent e

(object value : 1 -> 1)  # value(t):  runtime values of type t
(object bound : 1 -> 1)  # bound(t):  puts the * in *-autonomous

# Type level extent values and predicates
(object extent.zero : 0 -> 1) # zero constant
(object extent.nz : 1 -> 1)   # nonzero

# *definition*: 'nz e' above is equivalent to `¬ (e = extent.zero)`
# TODO: replace with equivalence + use ax-mp
(arrow extent.nz-def : extent.nz -> ({[e] extent.zero} eq not))

# "extent e" -> "index e"
(arrow extent.index-type : extent -> index)

################################################################################
# Declarations

# Extract the type variable from a value
(arrow value.type : value -> [t])

# Index methods
# zero index (only for non-zero extents, which have no indices)
(arrow index.zero : {[e.]
  ([.e] extent)           # given an extent
  ([.e] extent.nz |-)     # .. which is nonzero
} -> (index value))       # .. then there is a *zero* index for that extent

# Bound variables
# In traditional syntax:
#   η : t → (bound t ● value t)
#
# η takes a type metavariable, and returns:
#   bound t : a *bound* ("backwards flowing") value
#   value t : a runtime ("forwards flowing") value
#
# Think of this as 'bending' a wire from backwards to forwards.
(arrow bound.eta : [t] -> ([t . t t] {bound value})) # Given a type, create a *bound* variable

################################################################################
# Read-only, unowned array references

# `arrayref n t` represents a buffer of n elements of type t
(object arrayref : 2 -> 1)

# arrow n t → extent n
(arrow arrayref.extent : arrayref -> ([n t.n] extent))

# index an array reference
# arrayref n t ● Ix n → value t
(arrow arrayref.ix : {[n t.] ([.n t] arrayref value) ([.n] index value)} -> ([n t.t] value))

# array n t -> value t
(def-arrow arrayref.head : {[n t.]
  ([.n t] arrayref value)   # given an n-element array of values t
  ([.n] extent.nz |-)       # .. which is nonempty
} -> ([e t.t] value)  # .. return its 0th element
  = {[x p.]
  ([.x] value.type arrayref.extent [e.])
  ([.e p] index.zero [i.])
  ([.x i] arrayref.ix)
})

# given a closure mapping indices to values, materialize it as an array
# closure: index n → value t
# encoding: (index n)* ● value t
#(arrow materialize : {(index bound) value} -> array)

################################################################################
# Array ops

# Reductions!
# reduce :
#  extent e
#  ● (zero : value(r))
#  ● (add : bound(value(r)) ● bound(value(r)) ● value(r))
#  ● (xs : bound(index(e)) ● value(r))
#  -> value(r)
(arrow reduce : {[e r.]
  ([.e] extent value)
  ([.r] value) # zero : I → R
  ([.r r r] {bound bound value}) # add : R×R → R
  ([.e] index bound) # body : Index → R
  ([.r] value) # result: I → R
} -> ([e r.r] value))

################################################################################
# Dtypes & dtype methods

# F32 declarations
(object f32 : 0 -> 1)  # 32-bit floats (notice: no metavariable)
(arrow f32 : [] -> f32)                                    # constant f32 type
(arrow f32.from-index : (index value) -> ([e.] f32 value)) # convert an index to an f32. Inf if out of range.
(arrow f32.zero : [] -> (f32 value))                       # the f32 0 constant
(arrow f32.one : [] -> (f32 value))                        # the f32 1 constant
(arrow f32.add : {(f32 value) (f32 value)} -> (f32 value)) # add : f32 × f32 → f32
(arrow f32.mul : {(f32 value) (f32 value)} -> (f32 value)) # add : f32 × f32 → f32

################################################################################
# Built-in definitions

# Sum an array of F32 values
# f32.sum : extent e ● bound(index(e)) ● value(r) → value(r)
(def-arrow f32.sum : {[e.]
  ([.e e] {(extent value) (index bound)})
  (f32 value)
} -> ([e.] f32 value)
= {[e i x.]
  (f32.zero [zero.])
  (f32 bound.eta [acc_r acc.])
  (f32 bound.eta [val_r val.])
  ([.acc val] f32.add [combined.])
  ([.e zero acc_r val_r combined i x] reduce)
})

################################################################################
# Example programs

# my-array : Fn(Index) -> Dtype
# sum : (Fn(Index) -> Dtype) -> Dtype
# reduce :
#   (extent : SizeOfTheArray)
#   (zero : Index)
#   (add : Fn(Dtype, Dtype) -> Dtype)
#   (array : Fn(Index) -> Dtype)
#   ->
#   Dtype
#
# Fn(A) -> B
#  A* ● B

# extent e
# np.sum(range(0, n))
(def-arrow sum-range-f32 : (extent value) -> ([ev.] f32 value) = {[ev.]
  ([.ev] value.type [e.]) # get the type-level extent
  ([.e] extent.index-type bound.eta {[i] f32.from-index} [i x.])
  ([.ev i x] f32.sum)
})

# (i, j) → i + j
(def-arrow id-matrix-2d : {(index value) (index value)} -> ([i j.] f32 value) =
  ({f32.from-index f32.from-index} f32.add)
)

# (i, j) -> 1
(def-arrow ones-2d : {(index value) (index value)} -> ([i j.] f32 value) = ([i j.] f32.one))

(def-arrow matmul-id-ones : {(extent value) (index value) (index value)} -> ([e i k.] f32 value) = {[e i k.]
  ([.e jr v] f32.sum)

  # bind jr / j
  ([.e] value.type extent.index-type bound.eta [jr j.])

  # compute dot product
  ([. i j j k] {id-matrix-2d ones-2d} f32.mul [v.])
})

(def-arrow diag-ones-2d : (index value) -> ([i.] f32 value) = ([i. i i] ones-2d))

(def-arrow f32.increment : {(extent value) (index value)} -> ([e ix.] f32 value) = {[e ix.]
  ([.ix] f32.from-index {[i] f32.one} f32.add)
})
