# create a buffer from an index function
(def program materialize-index-producer :
  ([n.] {1 ([.n] ix val)})
  ->
  ([n.] (u64 val))
= ([env i.] u64.one))

(def program materialize-indexes :
  ({[n] u64} :)
  ->
  ([n.] (cap.own mem))
= ([len.]
  {
    [.len]
    ({unit.intro (([.len] :.param) name.materialize-index-producer) [.len]}
      materializec)
  }
  buf.to-mem
))

# Copy a u64 buffer 
(def program materialize-copy-u64-producer :
  ([n.] {({cap.ref [.n] u64} buf val) ([.n] ix val)})
  ->
  ([n.] (u64 val))
= ([input i.]
  {[.i input]} ix
))

(def program materialize-copy-u64 :
  (cap.ref mem)
  ->
  (cap.own mem)
= (
  mem.cast.u64
  [len input.]
    {
      [.len]
      ({[.input] (([.len] :.param) name.materialize-copy-u64-producer) [.len]}
        materializec)
    }
    buf.to-mem
))
