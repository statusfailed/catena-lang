(theory syntax nat {

  (arr gpu.block : 0 -> 1)
  (arr gpu.thread : 0 -> 1)
  (arr gpu.global : 2 -> 1)
  (arr gpu.view : 1 -> 1)
  (arr gpu.shared : 3 -> 1)
  (arr 1d : 1 -> 1)
  (arr 2d : 2 -> 1)
  (arr 3d : 3 -> 1)
  (arr gpu.grid : 2 -> 1)

})

(theory data syntax {

  (arr gpu.grid.schedule :
    (({[block_dim] [thread_dim]} gpu.grid) val) ->
    ([block_dim thread_dim .] {(gpu.block val) (gpu.thread val)}))

  (arr gpu.view.group :
    {(gpu.block val) (gpu.thread val) (([block_size] extent) val)} ->
    (([block_size] gpu.view) val))

  (arr gpu.global.store :
    {([matrix] val) (([n] gpu.view) val) (f32 val)} ->
    ([matrix n . matrix] val))
})
