#include <stdint.h>

__global__ void user_f32_broadcast_add_singleton_matrix_inputs(uint64_t w0 /* tile_rows */, uint64_t w1 /* tile_cols */, uint64_t w2 /* grid_cols */, uint64_t w3 /* grid_rows */, float* w5 /* a */, float* w6 /* b */, float* w7 /* output */) {
    uint3 w8_block = blockIdx; /* w8: worker, w4: grid */
    uint3 w8_thread = threadIdx; /* w8: worker, w4: grid */
    uint64_t w9_row = (uint64_t)w8_block.y * w0 + w8_thread.y; /* w9: ij, w8: worker, w0: tile_rows, w1: tile_cols */
    uint64_t w9_col = (uint64_t)w8_block.x * w1 + w8_thread.x; /* w9: ij, w8: worker, w0: tile_rows, w1: tile_cols */
    uint64_t w10 = w9_row; /* w10: i, w9: ij */
    uint64_t w11 = w9_col; /* w11: j, w9: ij */
    uint64_t w14_row = 0; /* w14: a_view, w11: j, w12: a_shape */
    uint64_t w14_col = w11; /* w14: a_view, w11: j, w12: a_shape */
    uint64_t w15_row = w10; /* w15: b_view, w10: i, w13: b_shape */
    uint64_t w15_col = 0; /* w15: b_view, w10: i, w13: b_shape */
    float w16 = w5[w14_row * (w2 * w1) + w14_col]; /* w16: a_value, w5: a, w14: a_view */
    float w17 = w6[w15_row * 1 + w15_col]; /* w17: b_value, w6: b, w15: b_view */
    float w18 = w16 + w17; /* w18: sum, w16: a_value, w17: b_value */
    w7[w9_row * (w2 * w1) + w9_col] = w18; /* w19: output_summed, w7: output, w9: ij, w18: sum */
    auto w19 = w7; /* w19: output_summed, w7: output, w9: ij, w18: sum */
    return; /* returns w19: output_summed */
}

void launch_user_f32_broadcast_add_singleton_matrix_inputs(uint64_t tile_rows, uint64_t tile_cols, uint64_t grid_cols, uint64_t grid_rows, float* a, float* b, float* output) {
    dim3 block(tile_cols, tile_rows);
    dim3 grid(grid_cols, grid_rows);
    user_f32_broadcast_add_singleton_matrix_inputs<<<grid, block>>>(tile_rows, tile_cols, grid_cols, grid_rows, a, b, output);
}
