# Top-level SmolLM2-1.7B forward pass.
#
# Every model tensor is an explicit input. The token-embedding matrix is used
# both by the embedding lookup and, because SmolLM2 ties its embeddings, by the
# language-model head. Each decoder layer applies the same program to distinct
# weights.

(def program smollm2.forward :
  ([n h q v i.] {
    (cap.ref mem) # token IDs
    (cap.ref mem) # shared token-embedding / language-model-head weight
    ({[.n] u64} :) # token count
    ({[.h] u64} :) # attention heads
    ({[.q] u64} :) # channels per attention head
    ({({[.h] [.q]} *) u64} :) # hidden size
    ({[.v] u64} :) # vocabulary size
    ({({[.n] ({[.h] [.q]} *)} *) u64} :) # tokens * hidden size
    ({({[.v] ({[.h] [.q]} *)} *) u64} :) # vocabulary size * hidden size
    ({({[.n] [.v]} *) u64} :) # tokens * vocabulary size
    ({[.i] u64} :) # MLP intermediate size
    ({({[.n] [.i]} *) u64} :) # tokens * intermediate size
    ({({({[.h] [.q]} *) ({[.h] [.q]} *)} *) u64} :) # hidden projection weight size
    ({({[.i] ({[.h] [.q]} *)} *) u64} :) # MLP rectangular weight size
    ({({({[.h] [.q]} *) [.i]} *) u64} :) # MLP down-projection weight size
    # decoder layer 00
    (cap.ref mem)
    (cap.ref mem)
    (cap.ref mem)
    (cap.ref mem)
    (cap.ref mem)
    (cap.ref mem)
    (cap.ref mem)
    (cap.ref mem)
    (cap.ref mem)
    # decoder layer 01
    (cap.ref mem)
    (cap.ref mem)
    (cap.ref mem)
    (cap.ref mem)
    (cap.ref mem)
    (cap.ref mem)
    (cap.ref mem)
    (cap.ref mem)
    (cap.ref mem)
    # decoder layer 02
    (cap.ref mem)
    (cap.ref mem)
    (cap.ref mem)
    (cap.ref mem)
    (cap.ref mem)
    (cap.ref mem)
    (cap.ref mem)
    (cap.ref mem)
    (cap.ref mem)
    # decoder layer 03
    (cap.ref mem)
    (cap.ref mem)
    (cap.ref mem)
    (cap.ref mem)
    (cap.ref mem)
    (cap.ref mem)
    (cap.ref mem)
    (cap.ref mem)
    (cap.ref mem)
    # decoder layer 04
