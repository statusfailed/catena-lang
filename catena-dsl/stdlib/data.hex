# basic datatypes
(theory type nat {
  # booleans
  # NOTE: booleans are special because they appear in `assert`
  (arr bool : 0 -> 1)

  # *type level* bool values
  (arr bool.t : 0 -> 1)
  (arr bool.f : 0 -> 1)

  # u64
  (arr u64 : 0 -> 1)
})

(theory program type {
  # assert (b : bool) -> (|- b = true)
  (arr assert : ({[b] bool} :) -> ({[b] bool.f} = |-))

  # assert-then : (b : bool) (|- b = true => p) -> (|- p)
  # implementation: ({ assert [h] } ax-mp )
  (def assert-then : {[b p.]
    ({[.b] bool} :)
    ({({[.b] bool.f} =) [.p]} ==> |-)
  } -> ([b p . p] |-) = ({assert [h]} ax-mp))

  # Boolean type literal.
  (arr bool.type : [] -> bool)

  # Boolean operations
  (arr bool.t : [] -> (bool val))
  (arr bool.f : [] -> (bool val))

  (arr bool.not : (bool val) -> (bool val))
  (arr bool.or  : {(bool val) (bool val)} -> (bool val))
  (arr bool.and : {(bool val) (bool val)} -> (bool val))

  # execute one of two *closures* depending on a boolean flag
  #
  #   if : 2 ● (A => B) ● (A => B) -> (A => B)
  (arr bool.if : {bool (=> val)} -> (=> val))

  # Execute one of two *converted closures* depending on a flag
  # (A "converted closure" is an explicit environment plus a fn pointer)
  #
  #   ifc : X ● (X * A -> B) ● Y ● (Y * A -> B) ● Bool ● A -> B
  #
  # (shorthand above assumes everything wrapped in `Value`)
  (arr bool.ifc : {[x y a b.]
    ([.x])
    ([.x a] {* [.b]} -> val)
    ([.y])
    ([.y a] {* [.b]} -> val)
    (bool val)
    ([.a])
  } -> ([x y a b . b]))


  # temp helpers until we add polymorphic versions
  # unitors and associators for bools only
  (arr bool.id : (bool val) -> (bool val))
  (arr bool.copy : (bool val) -> {(bool val) (bool val)})
  (def bool.li : (bool val) -> {1 (bool val)} = {unit.intro [a]})
})
