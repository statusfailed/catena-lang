# Finitary closed monoidal structure plus lifting from function pointers
(theory type nat { 
  # function types
  (arr => : 2 -> 1)
})

(theory program type {
  # defer A -> (1 => A)
  (arr defer : [a] -> ({1 [a]} =>))

  # run : (1 => A) -> A
  (arr run : ({1 [a]} =>) -> [a])

  # compose : (A => B) * (B => C) -> (A => C)
  (arr compose : {[a b c.]
    ([. a b] =>)
    ([. b c] =>)
  } -> ([a b c . a c] =>))

  # tensor : (A0 => B0) * (A1 => B1) -> (A0 * A1 => B0 * B1)
  (arr tensor : {[a0 b0 a1 b1.]
    ([. a0 b0] =>)
    ([. a1 b1] =>)
  } -> {[a0 b0 a1 b1.]
    ([. a0 a1] * [src.])
    ([. b0 b1] * [tgt.])
    ([. src tgt] =>)
  })

  # Additional to CMC structure
  # (A -> B) -> (A => B)
  (arr lift : (-> val) -> =>)
})
