# goal: generate StructuredProgram from this which ends up like
# void not(x0: bool, x1: *bool) { ... }
# note: return values are always passed as ptrs

# Boolean examples
(def program not : bool -> bool = bool.not)
(def program run-not : bool -> bool = ({defer (name.bool.not lift)} compose run))

########################################
# Tests that product types can be synthesized
(def program test-name.bool.li : [] -> ( {bool ({1 bool} *)} -> ) = name.bool.li)

