# goal: generate StructuredProgram from this which ends up like
# void not(x0: bool, x1: *bool) { ... }
# note: return values are always passed as ptrs

# Boolean examples
(def program not : (bool val) -> (bool val) = bool.not)

# Test we can use other definnitions
(def program use-not : (bool val) -> (bool val) = not)

#(def program run-not : (bool val) -> (bool val) = ({defer (name.bool.not lift)} compose run))
(def program check-defer : (bool val) -> (bool val) = ({defer (name.bool.not lift)} compose run))

(def program test-ifc : {(bool val) (bool val)} -> (bool val) = ([flag arg.]
  {bool.t name.bool.and bool.t name.bool.or [. flag arg]}
  bool.ifc
))

########################################
# Minimal packed-product example.
# This returns one value of type (1 * bool), not two free tensor outputs.

(def program run-li : [] -> ({1 (bool val)} *) = (
  {(bool.t defer) (name.bool.li lift)}
  compose
  run
))

# Exposing function pointers on an entrypoint is intentionally unsupported for now.
#(def program test-name.bool.li : [] -> ( {(bool val) ({1 (bool val)} *)} ->) = name.bool.li)

# Test that a product type inside another program synthesizes
(def program run-copy : [] -> ({(bool val) (bool val)} *) = (
  {(bool.t defer) (name.bool.copy lift)}
  compose
  run
))


# Testing monomorphisation
(def program id : [a] -> [a] = [x])
(def program use-id : (bool val) -> (bool val) = id)

# u64 arithmetic example: (1 + 1) * (1 + 1)
(def program two-times-two : [] -> (u64 val) = (
  ({u64.one u64.one} u64.add)
  {[x . x x]}
  u64.mul
))

# Cast owned memory to a u64 buffer, assert it is non-empty, then read element 0.
(def program array-head-u64 : ([n.] (cap.own mem)) -> ([n.] (u64 val)) = (
  mem.cast.u64
  {
    (u64.assert-nz ix.zero)
    [b]
  }
  ix
))
