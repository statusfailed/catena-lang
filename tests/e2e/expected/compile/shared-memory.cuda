#include <stdint.h>

__global__ void user_f32_shared_one(uint64_t scratch_size, float* out) {
    extern __shared__ float __shared_mem[];
    float* scratch = __shared_mem;

    uint3 worker_block = blockIdx;
    uint3 worker_thread = threadIdx;
    uint64_t out_view = (uint64_t)worker_block.x * blockDim.x + worker_thread.x;
    float one = 1.0f;
    scratch[worker_thread.x] = one;
    auto scratch_filled = scratch;
    float from_scratch = scratch_filled[worker_thread.x];
    out[out_view] = from_scratch;
    auto out_filled = out;
    return;
}

void launch_user_f32_shared_one(uint64_t block_count, uint64_t thread_count, float* out) {
    uint64_t scratch_size = thread_count;

    dim3 block(thread_count);
    dim3 grid(block_count);
    user_f32_shared_one<<<grid, block, (scratch_size) * sizeof(float)>>>(scratch_size, out);
}
