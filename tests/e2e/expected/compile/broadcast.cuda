#include <stdint.h>

__global__ void user_f32_broadcast_add(uint64_t w0 /* rows */, uint64_t w1 /* cols */, uint64_t w2 /* tile_rows */, uint64_t w3 /* tile_cols */, float* w5 /* a */, float* w6 /* b */, float* w7 /* output */) {
    uint3 w8_block = blockIdx; /* w8: worker, w4: grid */
    uint3 w8_thread = threadIdx; /* w8: worker, w4: grid */
    uint64_t w9_row = (uint64_t)w8_block.y * w2 + w8_thread.y; /* w9: ij, w8: worker, w2: tile_rows, w3: tile_cols */
    uint64_t w9_col = (uint64_t)w8_block.x * w3 + w8_thread.x; /* w9: ij, w8: worker, w2: tile_rows, w3: tile_cols */
    uint64_t w10 = w9_row; /* w10: i, w9: ij */
    uint64_t w11 = w9_col; /* w11: j, w9: ij */
    float w12 = w5[w10]; /* w12: a_value, w5: a, w10: i */
    float w13 = w6[w11]; /* w13: b_value, w6: b, w11: j */
    float w14 = w12 + w13; /* w14: sum, w12: a_value, w13: b_value */
    w7[w9_row * w1 + w9_col] = w14; /* w15: output_summed, w7: output, w9: ij, w14: sum */
    auto w15 = w7; /* w15: output_summed, w7: output, w9: ij, w14: sum */
    return; /* returns w15: output_summed */
}

void launch_user_f32_broadcast_add(uint64_t rows, uint64_t cols, uint64_t tile_rows, uint64_t tile_cols, float* a, float* b, float* output) {
    dim3 block(tile_cols, tile_rows);
    dim3 grid(((cols + tile_cols - 1) / tile_cols), ((rows + tile_rows - 1) / tile_rows));
    user_f32_broadcast_add<<<grid, block>>>(rows, cols, tile_rows, tile_cols, a, b, output);
}
