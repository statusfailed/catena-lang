#include <stdint.h>

__global__ void user_f32_two_shared_two_global(uint64_t w0 /* block_count */, uint64_t w1 /* thread_count */, uint64_t w2 /* tile_rows */, uint64_t w3 /* tile_cols */, uint64_t w5_size /* tile_a_size */, uint64_t w6_size /* tile_b_size */, float* w7 /* out_a */, float* w8 /* out_b */) {
    extern __shared__ float __shared_mem[];
    float* w5 = __shared_mem;
    float* w6 = __shared_mem + (w5_size);

    uint3 w9_block = blockIdx; /* w9: worker, w4: grid */
    uint3 w9_thread = threadIdx; /* w9: worker, w4: grid */
    float w10 = 1.0f; /* w10: one */
    float w11 = 0.0f; /* w11: zero */
    w5[w9_thread.x] = w10; /* w12: tile_a_filled, w5: tile_a, w9: worker, w10: one */
    auto w12 = w5; /* w12: tile_a_filled, w5: tile_a, w9: worker, w10: one */
    w6[w9_thread.x] = w11; /* w13: tile_b_filled, w6: tile_b, w9: worker, w11: zero */
    auto w13 = w6; /* w13: tile_b_filled, w6: tile_b, w9: worker, w11: zero */
    float w14 = w12[w9_thread.x]; /* w14: from_tile_a, w12: tile_a_filled, w9: worker */
    float w15 = w13[w9_thread.x]; /* w15: from_tile_b, w13: tile_b_filled, w9: worker */
    w7[w9_block.x * w1 + w9_thread.x] = w14; /* w16: out_a_filled, w7: out_a, w9: worker, w14: from_tile_a */
    auto w16 = w7; /* w16: out_a_filled, w7: out_a, w9: worker, w14: from_tile_a */
    w8[w9_block.x * w1 + w9_thread.x] = w15; /* w17: out_b_filled, w8: out_b, w9: worker, w15: from_tile_b */
    auto w17 = w8; /* w17: out_b_filled, w8: out_b, w9: worker, w15: from_tile_b */
    return; /* returns w12: tile_a_filled, w13: tile_b_filled, w16: out_a_filled, w17: out_b_filled */
}

void launch_user_f32_two_shared_two_global(uint64_t block_count, uint64_t thread_count, uint64_t tile_rows, uint64_t tile_cols, float* out_a, float* out_b) {
    uint64_t w5_size = tile_rows * tile_cols;
    uint64_t w6_size = tile_rows * tile_cols;

    dim3 block(thread_count);
    dim3 grid(block_count);
    user_f32_two_shared_two_global<<<grid, block, (w5_size + w6_size) * sizeof(float)>>>(block_count, thread_count, tile_rows, tile_cols, w5_size, w6_size, out_a, out_b);
}
