#include <stdint.h>

__global__ void user_f32_map_add_ten(float* w3 /* a */, float* w4 /* output */) {
    uint3 w5_block = blockIdx; /* w5: worker, w2: grid */
    uint3 w5_thread = threadIdx; /* w5: worker, w2: grid */
    uint64_t w6 = (uint64_t)w5_block.x * blockDim.x + w5_thread.x; /* w6: view, w5: worker */
    float w7 = w3[w6]; /* w7: a_value, w3: a, w6: view */
    float w8 = 1.0f; /* w8: one */
    float w9 = w8 + w8; /* w9: two, w8: one */
    float w10 = w9 + w9; /* w10: four, w9: two */
    float w11 = w10 + w10; /* w11: eight, w10: four */
    float w12 = w11 + w9; /* w12: ten, w11: eight, w9: two */
    float w13 = w7 + w12; /* w13: mapped, w7: a_value, w12: ten */
    w4[w6] = w13; /* w14: output_mapped, w4: output, w6: view, w13: mapped */
    auto w14 = w4; /* w14: output_mapped, w4: output, w6: view, w13: mapped */
    return; /* returns w14: output_mapped */
}

void launch_user_f32_map_add_ten(uint64_t block_count, uint64_t thread_count, float* a, float* output) {
    dim3 block(thread_count);
    dim3 grid(block_count);
    user_f32_map_add_ten<<<grid, block>>>(a, output);
}
