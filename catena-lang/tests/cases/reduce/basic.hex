# Examples using source-level reduce. These should exercise closure conversion
# from reduce to reducec.

# Produce one u64 value at each index.
(def program u64.one-at :
  ([n.] ([.n] ix val))
  ->
  ([n.] (u64 val))
= ([i.] u64.one))

# Adapter from the reduce accumulator closure convention to direct u64.add.
(def program u64.add-reduce :
  ({(u64 val) (u64 val)} *)
  ->
  (u64 val)
= ([pair.]
  ([.pair] *.elim [acc value.])
  {[.acc value]} u64.add
))

# Sum elements using source-level reduce. The caller supplies an ascribed length
# value; when it is zero, runtime execution should return the zero input without
# entering the loop.
(def program sum-u64-reduce-with-len :
  ([n.] ({[.n] u64} :))
  ->
  ([n.] (u64 val))
= ([n.]
  ([.n] :.ty [reduce-len producer-len.]
    {
      const.u64.0x0000000000000000
      (name.u64.add-reduce lift)
      ([.producer-len] name.u64.one-at lift)
      [.reduce-len]
    }
    reduce
  )
))

# Nullary empty-sum wrapper using the zero length witness.
(def program sum-empty-u64-reduce :
  []
  ->
  (u64 val)
= (u64.zero sum-u64-reduce-with-len))
