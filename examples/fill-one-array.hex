#
# Set every element of an array to 1.0
#

(def data user.f32.fill-one : 
    {
      (([.block_size] extent) val)
      (([.n] extent) val)
      (gpu.block val)
      (gpu.thread val)
      (({f32 [n]} gpu.global.1d) val)
     } -> (({f32 [n]} gpu.global.1d) val)
    = {[block_size n block thread out.]
      ([.] f32.one [one.])
      ([.block thread block_size] gpu.view.group [out_view.])
      ([.out out_view one] gpu.global.store [out_filled.])
      [.out_filled]}
)
