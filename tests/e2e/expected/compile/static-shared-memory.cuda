#include <stdint.h>

__global__ void user_f32_static_shared_one(uint64_t w0 /* global_rows */, uint64_t w1 /* global_cols */, uint64_t w2 /* tile_rows */, uint64_t w3 /* tile_cols */, uint64_t w5_size /* tile_size */, float* w6 /* out */) {
    extern __shared__ float __shared_mem[];
    float* w5 = __shared_mem;

    uint3 w7_block = blockIdx; /* w7: worker, w4: grid */
    uint3 w7_thread = threadIdx; /* w7: worker, w4: grid */
    uint64_t w8_row = (uint64_t)w7_block.y * w2 + w7_thread.y; /* w8: out_view, w7: worker, w2: tile_rows, w3: tile_cols */
    uint64_t w8_col = (uint64_t)w7_block.x * w3 + w7_thread.x; /* w8: out_view, w7: worker, w2: tile_rows, w3: tile_cols */
    float w9 = 1.0f; /* w9: one */
    w5[w7_thread.x] = w9; /* w10: tile_filled, w5: tile, w7: worker, w9: one */
    auto w10 = w5; /* w10: tile_filled, w5: tile, w7: worker, w9: one */
    float w11 = w10[w7_thread.x]; /* w11: from_tile, w10: tile_filled, w7: worker */
    w6[w8_row * w1 + w8_col] = w11; /* w12: out_filled, w6: out, w8: out_view, w11: from_tile */
    auto w12 = w6; /* w12: out_filled, w6: out, w8: out_view, w11: from_tile */
    return; /* returns w10: tile_filled, w12: out_filled */
}

void launch_user_f32_static_shared_one(uint64_t global_rows, uint64_t global_cols, uint64_t tile_rows, uint64_t tile_cols, float* out) {
    uint64_t w5_size = tile_rows * tile_cols;

    dim3 block(tile_rows, tile_cols);
    dim3 grid(((global_rows + tile_rows - 1) / tile_rows), ((global_cols + tile_cols - 1) / tile_cols));
    user_f32_static_shared_one<<<grid, block, (w5_size) * sizeof(float)>>>(global_rows, global_cols, tile_rows, tile_cols, w5_size, out);
}
