# This file sketches the Catena "state schema" idea.
#
# Goal:
#
#   Control-flow diagrams should carry an opaque `matmul.state` wire:
#
#     matmul.state -> matmul.state
#
#   Dataflow definitions should still be able to describe what changes inside
#   that state without manually unpacking and repacking every unchanged field.
#
# A future Catena surface syntax could be:
#
#   (state matmul.state(tile_size, m, k, n) {
#     tile_size : ([.tile_size] extent value)
#     m         : ([.m] extent value)
#     k         : ([.k] extent value)
#     n         : ([.n] extent value)
#     current_tile : ([.k] index value)
#     block     : (gpu.block value)
#     thread    : (gpu.thread value)
#     a         : (({f32 [m] [k]} gpu.global) value)
#     b         : (({f32 [k] [n]} gpu.global) value)
#     c         : (({f32 [m] [n]} gpu.global) unique)
#     tile_a    : (({f32 [tile_size] [tile_size]} gpu.shared) unique)
#     tile_b    : (({f32 [tile_size] [tile_size]} gpu.shared) unique)
#     acc       : (f32 value)
#   })
#
# The rest of the file shows the post-expansion form that metacat sees:
# ordinary first-order objects and arrows.

(theory syntax nat {
  (arr nat : 0 -> 1)
  (arr extent : 1 -> 1)
  (arr index : 1 -> 1)
  (arr bool : 0 -> 1)
  (arr condition : 4 -> 1)
  (arr f32 : 0 -> 1)
  (arr gpu.block : 0 -> 1)
  (arr gpu.thread : 0 -> 1)
  (arr gpu.global : 3 -> 1)
  (arr gpu.view : 1 -> 1)
  (arr gpu.shared : 3 -> 1)
  (arr matmul.state : 4 -> 1)
  (arr matmul.p-iteration : 4 -> 1)
  (arr done : 0 -> 1)

  (arr value : 1 -> 1)
  (arr unique : 1 -> 1)
  (arr bound : 1 -> 1)
  (arr loopback : 1 -> 1)

  (arr * : 2 -> 1)
  (arr + : 2 -> 1)
  (arr 1 : 0 -> 1)
  (arr 0 : 0 -> 1)
})

(theory data syntax {
  (arr done : [] -> (done value))
  (arr f32.zero : [] -> (f32 value))
  (arr f32.add : {(f32 value) (f32 value)} -> (f32 value))
  (arr f32.mul : {(f32 value) (f32 value)} -> (f32 value))
  (arr f32 : [] -> f32)
  (arr bound.eta : [t] -> ([t . t t] {bound value}))
  (arr reduce :
    {
      (extent value)
      ([x] value)
      ([x] bound)
      (([tile_size] index) bound)
      ([x] value)
    } ->
    ([tile_size x x tile_size x . x] value))
  (arr extent.index-type :
    (([x] extent) value) ->
    ([x] index))
  (arr thread.x :
    {
      (([tile_size] extent) value)
      (gpu.thread value)
    } ->
    (([tile_size] index) value))
  (arr thread.y :
    {
      (([tile_size] extent) value)
      (gpu.thread value)
    } ->
    (([tile_size] index) value))
  (arr gpu.shared.load :
    {[tile ix iy]} ->
    ([tile ix iy .] f32 value))
  (arr gpu.view.thread :
    ([tile_size . tile_size] {
      (extent value)
      (gpu.thread value)
    }) ->
    (([tile_size] gpu.view) value))
  (arr gpu.view.block-row-current-tile-col :
    ([tile_size k . tile_size k] {
      (extent value)
      (index value)
      (gpu.block value)
      (gpu.thread value)
    }) ->
    (([tile_size k . tile_size] gpu.view) value))
  (arr gpu.view.current-tile-row-block-col :
    ([tile_size k . tile_size k] {
      (extent value)
      (index value)
      (gpu.block value)
      (gpu.thread value)
    }) ->
    (([tile_size k . tile_size] gpu.view) value))
  (arr gpu.view.group-by-tile :
    ([tile_size . tile_size] {
      (extent value)
      (gpu.block value)
      (gpu.thread value)
    }) ->
    (([tile_size] gpu.view) value))
  (arr gpu.global.load :
    ([matrix tile_size . matrix tile_size] {
      (value)
      (([tile_size] gpu.view) value)
    }) ->
    ([matrix tile_size .] f32 value))
  (arr gpu.global.store :
    ([matrix tile_size . matrix tile_size] {
      (unique)
      (([tile_size] gpu.view) value)
      (f32 value)
    }) ->
    ([matrix tile_size . matrix] unique))
  (arr gpu.shared.store :
    ([tile tile_size . tile tile_size] {
      (unique)
      (([tile_size] gpu.view) value)
      (f32 value)
    }) ->
    ([tile tile_size . tile] unique))
  (arr ceil-div :
    ([tile_size m k n . k tile_size] {
      (extent value)
      (extent value)
    }) ->
    ([tile_size m k n . k] extent value))
  (arr index.lt-extent :
    ([tile_size m k n . k k] {
      (index value)
      (extent value)
    }) ->
    (({[tile_size] [m] [k] [n]} condition) value))
  (arr index.succ :
    (([x] index) value) ->
    (([x] index) value))
  (arr guard :
    ([x c . x c] {
      (value)
      (value)
    }) ->
    ([x c . x x] ({
      (value)
      (value)
    } +)))

  # The following lenses are generated from the surface `state` schema. Each
  # lens is implemented by unpacking every field, projecting or replacing one
  # field, then packing the complete state again.
  (arr matmul.state.pack :
    ([tile_size m k n .
      tile_size m k n k m k k n m n tile_size tile_size tile_size tile_size] {
      (extent value)
      (extent value)
      (extent value)
      (extent value)
      (index value)
      (gpu.block value)
      (gpu.thread value)
      (({f32 [m] [k]} gpu.global) value)
      (({f32 [k] [n]} gpu.global) value)
      (({f32 [m] [n]} gpu.global) unique)
      (({f32 [tile_size] [tile_size]} gpu.shared) unique)
      (({f32 [tile_size] [tile_size]} gpu.shared) unique)
      (f32 value)
    }) ->
    (({[tile_size] [m] [k] [n]} matmul.state) value))

  (arr matmul.state.unpack :
    (({[tile_size] [m] [k] [n]} matmul.state) value) ->
    ([tile_size m k n .
      tile_size m k n k m k k n m n tile_size tile_size tile_size tile_size] {
      (extent value)
      (extent value)
      (extent value)
      (extent value)
      (index value)
      (gpu.block value)
      (gpu.thread value)
      (({f32 [m] [k]} gpu.global) value)
      (({f32 [k] [n]} gpu.global) value)
      (({f32 [m] [n]} gpu.global) unique)
      (({f32 [tile_size] [tile_size]} gpu.shared) unique)
      (({f32 [tile_size] [tile_size]} gpu.shared) unique)
      (f32 value)
    }))

  (def matmul.state.tile-size.get :
    (({[tile_size] [m] [k] [n]} matmul.state) value) ->
    ([tile_size m k n . tile_size m k n tile_size] {
      (matmul.state value)
      (extent value)
    })
    =
    {[state.]
      ([.state] matmul.state.unpack
        [tile_size m k n current_tile block thread a b c tile_a tile_b acc.])
      ([.tile_size m k n current_tile block thread a b c tile_a tile_b acc]
        matmul.state.pack
        [state_out.])
      ([.state_out tile_size])
    })

  (def matmul.state.k.get :
    (({[tile_size] [m] [k] [n]} matmul.state) value) ->
    ([tile_size m k n . tile_size m k n k] {
      (matmul.state value)
      (extent value)
    })
    =
    {[state.]
      ([.state] matmul.state.unpack
        [tile_size m k n current_tile block thread a b c tile_a tile_b acc.])
      ([.tile_size m k n current_tile block thread a b c tile_a tile_b acc]
        matmul.state.pack
        [state_out.])
      ([.state_out k])
    })

  (def matmul.state.current-tile.get :
    (({[tile_size] [m] [k] [n]} matmul.state) value) ->
    ([tile_size m k n . tile_size m k n k] {
      (matmul.state value)
      (index value)
    })
    =
    {[state.]
      ([.state] matmul.state.unpack
        [tile_size m k n current_tile block thread a b c tile_a tile_b acc.])
      ([.tile_size m k n current_tile block thread a b c tile_a tile_b acc]
        matmul.state.pack
        [state_out.])
      ([.state_out current_tile])
    })

  (def matmul.state.current-tile.put :
    ([tile_size m k n . tile_size m k n k] {
      (matmul.state value)
      (index value)
    }) ->
    (({[tile_size] [m] [k] [n]} matmul.state) value)
    =
    {[state field.]
      ([.state] matmul.state.unpack
        [tile_size m k n _current_tile block thread a b c tile_a tile_b acc.])
      ([.tile_size m k n field block thread a b c tile_a tile_b acc]
        matmul.state.pack
        [updated_state.])
      ([.updated_state])
    })

  (def matmul.state.block.get :
    (({[tile_size] [m] [k] [n]} matmul.state) value) ->
    ([tile_size m k n . tile_size m k n] {
      (matmul.state value)
      (gpu.block value)
    })
    =
    {[state.]
      ([.state] matmul.state.unpack
        [tile_size m k n current_tile block thread a b c tile_a tile_b acc.])
      ([.tile_size m k n current_tile block thread a b c tile_a tile_b acc]
        matmul.state.pack
        [state_out.])
      ([.state_out block])
    })

  (def matmul.state.thread.get :
    (({[tile_size] [m] [k] [n]} matmul.state) value) ->
    ([tile_size m k n . tile_size m k n] {
      (matmul.state value)
      (gpu.thread value)
    })
    =
    {[state.]
      ([.state] matmul.state.unpack
        [tile_size m k n current_tile block thread a b c tile_a tile_b acc.])
      ([.tile_size m k n current_tile block thread a b c tile_a tile_b acc]
        matmul.state.pack
        [state_out.])
      ([.state_out thread])
    })

  (def matmul.state.a.get :
    (({[tile_size] [m] [k] [n]} matmul.state) value) ->
    ([tile_size m k n . tile_size m k n m k] {
      (matmul.state value)
      (({f32 [m] [k]} gpu.global) value)
    })
    =
    {[state.]
      ([.state] matmul.state.unpack
        [tile_size m k n current_tile block thread a b c tile_a tile_b acc.])
      ([.tile_size m k n current_tile block thread a b c tile_a tile_b acc]
        matmul.state.pack
        [state_out.])
      ([.state_out a])
    })

  (def matmul.state.b.get :
    (({[tile_size] [m] [k] [n]} matmul.state) value) ->
    ([tile_size m k n . tile_size m k n k n] {
      (matmul.state value)
      (({f32 [k] [n]} gpu.global) value)
    })
    =
    {[state.]
      ([.state] matmul.state.unpack
        [tile_size m k n current_tile block thread a b c tile_a tile_b acc.])
      ([.tile_size m k n current_tile block thread a b c tile_a tile_b acc]
        matmul.state.pack
        [state_out.])
      ([.state_out b])
    })

  (def matmul.state.c.get :
    (({[tile_size] [m] [k] [n]} matmul.state) value) ->
    ([tile_size m k n . tile_size m k n m n] {
      (matmul.state value)
      (({f32 [m] [n]} gpu.global) unique)
    })
    =
    {[state.]
      ([.state] matmul.state.unpack
        [tile_size m k n current_tile block thread a b c tile_a tile_b acc.])
      ([.tile_size m k n current_tile block thread a b c tile_a tile_b acc]
        matmul.state.pack
        [state_out.])
      ([.state_out c])
    })

  (def matmul.state.c.put :
    ([tile_size m k n . tile_size m k n m n] {
      (matmul.state value)
      (({f32 [m] [n]} gpu.global) unique)
    }) ->
    (({[tile_size] [m] [k] [n]} matmul.state) value)
    =
    {[state field.]
      ([.state] matmul.state.unpack
        [tile_size m k n current_tile block thread a b _c tile_a tile_b acc.])
      ([.tile_size m k n current_tile block thread a b field tile_a tile_b acc]
        matmul.state.pack
        [updated_state.])
      ([.updated_state])
    })

  (def matmul.state.tile-a.get :
    (({[tile_size] [m] [k] [n]} matmul.state) value) ->
    ([tile_size m k n . tile_size m k n tile_size tile_size] {
      (matmul.state value)
      (({f32 [tile_size] [tile_size]} gpu.shared) unique)
    })
    =
    {[state.]
      ([.state] matmul.state.unpack
        [tile_size m k n current_tile block thread a b c tile_a tile_b acc.])
      ([.tile_size m k n current_tile block thread a b c tile_a tile_b acc]
        matmul.state.pack
        [state_out.])
      ([.state_out tile_a])
    })

  (def matmul.state.tile-a.put :
    ([tile_size m k n . tile_size m k n tile_size tile_size] {
      (matmul.state value)
      (({f32 [tile_size] [tile_size]} gpu.shared) unique)
    }) ->
    (({[tile_size] [m] [k] [n]} matmul.state) value)
    =
    {[state field.]
      ([.state] matmul.state.unpack
        [tile_size m k n current_tile block thread a b c _tile_a tile_b acc.])
      ([.tile_size m k n current_tile block thread a b c field tile_b acc]
        matmul.state.pack
        [updated_state.])
      ([.updated_state])
    })

  (def matmul.state.tile-b.get :
    (({[tile_size] [m] [k] [n]} matmul.state) value) ->
    ([tile_size m k n . tile_size m k n tile_size tile_size] {
      (matmul.state value)
      (({f32 [tile_size] [tile_size]} gpu.shared) unique)
    })
    =
    {[state.]
      ([.state] matmul.state.unpack
        [tile_size m k n current_tile block thread a b c tile_a tile_b acc.])
      ([.tile_size m k n current_tile block thread a b c tile_a tile_b acc]
        matmul.state.pack
        [state_out.])
      ([.state_out tile_b])
    })

  (def matmul.state.tile-b.put :
    ([tile_size m k n . tile_size m k n tile_size tile_size] {
      (matmul.state value)
      (({f32 [tile_size] [tile_size]} gpu.shared) unique)
    }) ->
    (({[tile_size] [m] [k] [n]} matmul.state) value)
    =
    {[state field.]
      ([.state] matmul.state.unpack
        [tile_size m k n current_tile block thread a b c tile_a _tile_b acc.])
      ([.tile_size m k n current_tile block thread a b c tile_a field acc]
        matmul.state.pack
        [updated_state.])
      ([.updated_state])
    })

  (def matmul.state.shared.put :
    ([tile_size m k n . tile_size m k n tile_size tile_size tile_size tile_size] {
      (matmul.state value)
      (({f32 [tile_size] [tile_size]} gpu.shared) unique)
      (({f32 [tile_size] [tile_size]} gpu.shared) unique)
    }) ->
    (({[tile_size] [m] [k] [n]} matmul.state) value)
    =
    {[state tile_a tile_b.]
      ([.state] matmul.state.unpack
        [tile_size m k n current_tile block thread a b c _tile_a _tile_b acc.])
      ([.tile_size m k n current_tile block thread a b c tile_a tile_b acc]
        matmul.state.pack
        [updated_state.])
      ([.updated_state])
    })

  (def matmul.state.acc.get :
    (({[tile_size] [m] [k] [n]} matmul.state) value) ->
    ([tile_size m k n . tile_size m k n] {
      (matmul.state value)
      (f32 value)
    })
    =
    {[state.]
      ([.state] matmul.state.unpack
        [tile_size m k n current_tile block thread a b c tile_a tile_b acc.])
      ([.tile_size m k n current_tile block thread a b c tile_a tile_b acc]
        matmul.state.pack
        [state_out.])
      ([.state_out acc])
    })

  (def matmul.state.acc.put :
    ([tile_size m k n . tile_size m k n] {
      (matmul.state value)
      (f32 value)
    }) ->
    (({[tile_size] [m] [k] [n]} matmul.state) value)
    =
    {[state field.]
      ([.state] matmul.state.unpack
        [tile_size m k n current_tile block thread a b c tile_a tile_b _acc.])
      ([.tile_size m k n current_tile block thread a b c tile_a tile_b field]
        matmul.state.pack
        [updated_state.])
      ([.updated_state])
    })

  # A user writes this as:
  #
  #   defdata init-acc(s) =
  #     s.acc := 0
  #
  # Catena should lower it to:
  #
  #   f32.zero;
  #   matmul.state.acc.put
  #
  (def init-acc :
    (({[tile_size] [m] [k] [n]} matmul.state) value) ->
    (({[tile_size] [m] [k] [n]} matmul.state) value)
    =
    {[state.]
      ([.] f32.zero [zero.])
      ([.state zero] matmul.state.acc.put [updated_state.])
      ([.updated_state])
    })

  (def matmul.state.dot-by-thread :
    (({[tile_size] [m] [k] [n]} matmul.state) value) ->
    (({[tile_size] [m] [k] [n]} matmul.state) value)
    =
    {[state.]
      ([.state] matmul.state.tile-size.get [with_tile_size tile_size.])
      ([.with_tile_size] matmul.state.thread.get [with_thread thread.])
      ([.with_thread] matmul.state.tile-a.get [with_tile_a tile_a.])
      ([.with_tile_a] matmul.state.tile-b.get [with_tile_b tile_b.])
      ([.with_tile_b] matmul.state.acc.get [with_acc acc.])

      # for tile_inner_index in range(tile_size):
      #   acc += tile_A[thread.y, tile_inner_index] * tile_B[tile_inner_index, thread.x]
      ([.tile_size] extent.index-type bound.eta
        [tile_inner_index_r tile_inner_index.])
      ([.] f32 bound.eta
        [acc_r acc_q.])

      ([.tile_size thread] thread.y [thread_y.])
      ([.tile_size thread] thread.x [thread_x.])
      ([.tile_a thread_y tile_inner_index] gpu.shared.load
        [a_val.])
      ([.tile_b tile_inner_index thread_x] gpu.shared.load
        [b_val.])
      ([.a_val b_val] f32.mul [dot.])
      ([.acc_q dot] f32.add [acc_next.])

      ([.tile_size acc acc_r tile_inner_index_r acc_next]
        reduce
        [acc_out.])

      ([.with_acc acc_out] matmul.state.acc.put [updated_state.])
      ([.updated_state])
    })

  (def matmul.state.advance-current-tile :
    (({[tile_size] [m] [k] [n]} matmul.state) value) ->
    (({[tile_size] [m] [k] [n]} matmul.state) value)
    =
    {[state.]
      ([.state] matmul.state.current-tile.get [with_current_tile current_tile.])
      ([.current_tile] index.succ [next_tile.])
      ([.with_current_tile next_tile] matmul.state.current-tile.put [updated_state.])
      ([.updated_state])
    })

  (def matmul.state.store-output :
    (({[tile_size] [m] [k] [n]} matmul.state) value) ->
    ([tile_size m k n .] done value)
    =
    {[state.]
      ([.state] matmul.state.tile-size.get [with_tile_size tile_size.])
      ([.with_tile_size] matmul.state.block.get [with_block block.])
      ([.with_block] matmul.state.thread.get [with_thread thread.])
      ([.with_thread] matmul.state.c.get [with_c c.])
      ([.with_c] matmul.state.acc.get [with_acc acc.])
      ([.tile_size block thread] gpu.view.group-by-tile [c_view.])
      ([.c c_view acc] gpu.global.store [c_out.])
      ([.with_acc c_out] matmul.state.c.put [_updated_state.])
      ([.] done [done.])
      ([.done])
    })

  # A user writes this as:
  #
  #   defdata cooperative-global-to-shared(s) =
  #     s.tile_a[[s.thread]] =
  #       s.a.block_row_current_tile_col(s.tile_size, s.current_tile,
  #                                      s.block, s.thread)
  #     s.tile_b[[s.thread]] =
  #       s.b.current_tile_row_block_col(s.tile_size, s.current_tile,
  #                                      s.block, s.thread)
  #
  (def matmul.state.cooperative-global-to-shared :
    (({[tile_size] [m] [k] [n]} matmul.state) value) ->
    (({[tile_size] [m] [k] [n]} matmul.state) value)
    =
    {[state.]
      ([.state] matmul.state.tile-size.get [with_tile_size tile_size.])
      ([.with_tile_size] matmul.state.current-tile.get [with_current_tile current_tile.])
      ([.with_current_tile] matmul.state.block.get [with_block block.])
      ([.with_block] matmul.state.thread.get [with_thread thread.])
      ([.with_thread] matmul.state.a.get [with_a a.])
      ([.with_a] matmul.state.b.get [with_b b.])
      ([.with_b] matmul.state.tile-a.get [with_tile_a tile_a.])
      ([.with_tile_a] matmul.state.tile-b.get [with_tile_b tile_b.])
      ([.tile_size thread] gpu.view.thread [shared_thread_view.])

      ([.tile_size current_tile block thread]
        gpu.view.block-row-current-tile-col
        [a_view.])
      ([.a a_view] gpu.global.load [a_val.])
      ([.tile_a shared_thread_view a_val] gpu.shared.store
        [tile_a_loaded.])

      ([.tile_size current_tile block thread]
        gpu.view.current-tile-row-block-col
        [b_view.])
      ([.b b_view] gpu.global.load [b_val.])
      ([.tile_b shared_thread_view b_val] gpu.shared.store
        [tile_b_loaded.])

      ([.with_tile_b tile_a_loaded tile_b_loaded] matmul.state.shared.put [state_out.])
      ([.state_out])
    })

  # A user writes this as a condition over opaque state:
  #
  #   defdata has-more-tiles(s) =
  #     s.current_tile < ceil_div(s.k, s.tile_size)
  #
  (def matmul.state.has-more-tiles :
    (({[tile_size] [m] [k] [n]} matmul.state) value) ->
    ([tile_size m k n . tile_size m k n tile_size m k n] ({
      (matmul.state value)
      (matmul.state value)
    } +))
    =
    {[entry.]
      ([.entry] matmul.state.tile-size.get [with_tile_size tile_size.])
      ([.with_tile_size] matmul.state.k.get [with_k k_extent.])
      ([.with_k] matmul.state.current-tile.get [with_current_tile current_tile.])
      ([.k_extent tile_size] ceil-div [num_tiles.])
      ([.current_tile num_tiles] index.lt-extent [has_more.])
      ([.with_current_tile has_more] guard [branched.])
      ([.branched])
    })
})

(theory control syntax {
  # Control flow only sees the opaque state.
  (arr done : [] -> done)

  (arr branch : [x] -> [x . x x])
  (arr merge : [x . x x] -> [x])
  (arr gpu.sync : [x x . x x] -> [x x . x x])
  (arr value.with-type : ([x] value) -> ([x . x x] {value [x]}))
  (arr loop.cap : [x] -> ([x . x x] {loopback value}))
  (arr loop.cup : ([x . x x] {loopback value}) -> [x])
  (arr loop.merge : (value [x . x x]) -> ([x] value))

  (def gpu.tiled_matmul.controlflow :
    ([tile_size m k n . tile_size m k n tile_size m k n tile_size m k n] {
      (matmul.state value)
      (matmul.state value)
      (matmul.state value)
    }) ->
    ([tile_size m k n . tile_size m k n tile_size m k n tile_size m k n] {
      ([tile_size m k n .] done value)
      (matmul.state value)
      (matmul.state value)
    })
    =
    {[start after_loaded_phase after_compute_phase.]
      ([.start] data.init-acc [initialized.])
      ([.initialized] value.with-type [initialized_value loop_type.])
      ([.loop_type] loop.cap [loopback loop_iter.])
      ([.initialized_value loop_iter] loop.merge [loop_current.])

      ([.loop_current] data.matmul.state.has-more-tiles
        [has_more_tiles_iter loop_out.])

        # Load the current A/B tile fragments, then suspend at the load barrier.
        ([.has_more_tiles_iter] data.matmul.state.cooperative-global-to-shared [loaded.])
        ([.loaded after_loaded_phase] gpu.sync [x_loaded after_loaded_phase_out.])

        # Compute this tile contribution inside dataflow.
        ([.x_loaded] data.matmul.state.dot-by-thread [computed.])

        # Suspend before the next iteration can overwrite shared tiles.
        ([.computed after_compute_phase] gpu.sync [after_compute after_compute_phase_out.])
        ([.after_compute] data.matmul.state.advance-current-tile [next_iteration.])
        ([.loopback next_iteration] loop.cup [closed.])

      ([.loop_out] data.matmul.state.store-output [done.])
      ([.done after_loaded_phase_out after_compute_phase_out])
    })
})
