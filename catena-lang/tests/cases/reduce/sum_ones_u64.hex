# Source-level reduce example that sums one u64 for each input index.
#
# This intentionally uses `reduce`, not `reducec`: the producer closure is
# named under the length witness `n`, so closure conversion must lower it to a
# generated `name.closure.*` operation that still receives `n`.

# Produce one u64 value at each index.
(def program sum-ones.u64.one-at :
  ([n.] ([.n] ix val))
  ->
  ([n.] (u64 val))
= ([i.] u64.one))

# Adapter from the source-level reduce accumulator closure convention to direct
# u64.add.
(def program sum-ones.u64.add-reduce :
  ({(u64 val) (u64 val)} *)
  ->
  (u64 val)
= ([pair.]
  ([.pair] *.elim [acc value.])
  {[.acc value]} u64.add
))

# Sum one value for each index below the input length witness `n`. The input is
# an ascribed value `n : u64`, so runtime can pass it as a plain u64 while the
# source graph still has the type-level name `n`.
(def program sum-ones-u64-reduce :
  ([n.] ({[.n] u64} :))
  ->
  ([n.] (u64 val))
= ([n.]
  ([.n] :.ty [reduce-len producer-len.]
    {
      const.u64.0x0000000000000000
      (name.sum-ones.u64.add-reduce lift)
      ([.producer-len] name.sum-ones.u64.one-at lift)
      [.reduce-len]
    }
    reduce
  )
))
