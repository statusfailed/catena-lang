(theory syntax nat {
  # Products and coproducts
  (arr * : 2 -> 1)
  (arr + : 2 -> 1)

  # Units and Counits
  (arr 1 : 0 -> 1)
  (arr 0 : 0 -> 1)

  ########################################
  # Runtime vals
  # A 'val' is an anonymous runtime value.
  # Non-val types are erased at compile time.
  (arr val : 1 -> 1)

  ########################################
  # Type definitions

  # 2 is "bool"
  (def 2 : 0 -> 1 = ({1 1} +))

  ########################################
  # built in type definitions
  (arr f32 : 0 -> 1)
  (arr u32 : 0 -> 1)
  (arr extent : 1 -> 1)
  (arr nat.mul : 2 -> 1)
})

(theory data syntax {
  ########################################
  # val and packed tensors
  (arr val.*.elim  : (* val) -> {val val}) # Val(A) × Val(B) -> Val(A × B)
  (arr val.*.intro : {val val} -> (* val)) # Val(A × B) -> Val(A) × Val(B)

  ########################################
  # Strictified monoidal structure
  # Unitors
  (arr unitl.elim  : ({1 [a]} * val) -> val)
  (arr unitl.intro : val -> ({1 [a]} * val))
  #(arr unitr.elim  : ({[a] 1} val) -> val)
  #(arr unitr.intro : val -> ({[a] 1}) val)

  # Val(2) × Val(A) -> Val(A) + Val(A)
  (def if : {(2 val) ([a] val)} -> ([a . a a] {val val} +) = (
    [b a]               # Value(2)     × Value(A)
    {2.elim [a]}        # Value(1 + 1) × Value(A)
    val.*.intro         # Value((1 + 1) × A)
    control.distr       # Value((1×A) + (1×A))
    control.val.+.elim  # Value(1×A) + Value(1×A)
    control.elim2       # Value(A) + Value(A)
  ))

  ########################################
  # built in arrows

  # 2 ~= 1 + 1
  # TODO: move this to 'control' to avoid hackery?
  (arr 2.intro : ({1 1} + val) -> (2 val))
  (arr 2.elim  : (2 val) -> ({1 1} + val))

  (arr f32.zero : [] -> (f32 val))
  (arr f32.one : [] -> (f32 val))
  (arr f32.add : {(f32 val) (f32 val)} -> (f32 val))

  # unsigned 32-bit integers
  (arr u32.type : [] -> u32)
  (arr u32.zero : [] -> (u32 val))
  (arr u32.one  : [] -> (u32 val))
  (arr u32.max  : [] -> (u32 val))
  (arr u32.add  : {(u32 val) (u32 val)} -> (u32 val))
  (arr u32.eq   : {(u32 val) (u32 val)} -> (2 val))
})

(theory control syntax {
  # Reified type for 0
  (arr 0.type : [] -> 0)

  # val and packed tensors
  # Val(A + B) -> Val(A) + Val(B)
  (arr val.+.elim  : (+ val) -> {val val})
  # Val(A) + Val(B) -> Val(A + B)
  (arr val.+.intro : {val val} -> (+ val))


  # A×(B+C) → (A×B) + (A×C)
  (arr distl : ([a b c] {[a] +} * val) -> ([a b c.a b a c] {* *} + val))
  # (A+B)×C → (A×C) + (B×C)
  (arr distr : ([a b c] {+ [c]} * val) -> ([a b c.a c b c] {* *} + val))

  # Helper for 'if' - TODO: rename?
  # Val(1A) + Val(1A) -> Val(A) + Val(A)
  # ({1 [a]} * [x . x x] + val)
  (def elim2 : ({1 [a]} * val [v . v v]) -> (val [v . v v]) = {data.unitl.elim data.unitl.elim})

  # control-flow monoid structure on values
  # merge_A : value(A) + value(A) -> value(A)
  # never_A : I -> value(A)
  # NOTE: 'never' takes a *type* argument, not a *value* argument!
  (arr merge : (val [x . x x]) -> val)
  (arr never : [x] -> val)

  (arr u32.type : [] -> u32)
})
