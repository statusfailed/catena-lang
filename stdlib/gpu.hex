(theory syntax nat {

  (arr gpu.global : 2 -> 1)
  (arr gpu.view : 0 -> 1)
  (arr gpu.shape : 1 -> 1)
  (arr gpu.shared : 2 -> 1)
  (arr 1d : 1 -> 1)
  (arr 2d : 2 -> 1)
  (arr 3d : 3 -> 1)
  (arr 4d : 4 -> 1)
  (arr gpu.grid : 2 -> 1)

})

(theory data syntax {

  # Views describe logical coordinates, not physical address arithmetic.
  # Strides/layout are properties of the object being viewed.Those layouts can be chosen when grid/memory objects are created, but remain transparent to kernel code. 

  # Current worker position in the grid execution domain.
  # A 1D grid gives a product view [block_count] x [thread_count].
  # A 2D grid gives a hierarchical product view:
  #   ([grid_rows] x [grid_cols]) x ([tile_rows] x [tile_cols]).
  (arr gpu.grid.view :
    (({[block_dim] [thread_dim]} gpu.grid) val) ->
    ([block_dim thread_dim .] (gpu.view val)))

  # Convert a product/hierarchical worker view to a contiguous 1D view.
  # For a 1D worker view this is block.x * blockDim.x + thread.x.
  (arr gpu.view.linearize :
    (gpu.view val) ->
    (gpu.view val))

  # Group a linear 1D view into a 2D view with rows of `count` elements.
  # For example, with a row-major layout:
  #   row = view / count
  #   col = view % count
  (arr gpu.view.group :
    {(gpu.view val) (([count] extent) val)} ->
    ([count .] (gpu.view val)))

  # Reshape a linear 1D view into a 2D view with the requested shape.
  (arr gpu.view.reshape :
    {(gpu.view val) ([shape] gpu.shape)} ->
    ([shape .] (gpu.view val)))

  # Shape witnesses used by view operations. They carry no runtime data; they
  # make target shapes explicit in programs.
  (arr gpu.shape.row :
    (([cols] extent) val) ->
    (({1 [cols]} 2d) gpu.shape))

  (arr gpu.shape.row-mul :
    {(([lhs] extent) val) (([rhs] extent) val)} ->
    (({1 ({[lhs] [rhs]} nat.mul)} 2d) gpu.shape))

  (arr gpu.shape.col :
    (([rows] extent) val) ->
    (({[rows] 1} 2d) gpu.shape))

  (arr gpu.shape.col-mul :
    {(([lhs] extent) val) (([rhs] extent) val)} ->
    (({({[lhs] [rhs]} nat.mul) 1} 2d) gpu.shape))

  (arr gpu.shape.2d :
    {(([rows] extent) val) (([cols] extent) val)} ->
    (({[rows] [cols]} 2d) gpu.shape))

  # Map a 2D tiled worker view to a normal 2D data view.
  # For example, with row-major tile placement:
  # block position selects the tile, thread position selects the cell:
  #   row = block.y * tile_rows + thread.y
  #   col = block.x * tile_cols + thread.x
  (arr gpu.view.group-by-tile :
    {(gpu.view val) (([tile_rows] extent) val) (([tile_cols] extent) val)} ->
    ([tile_rows tile_cols .] (gpu.view val)))

  # Project the row coordinate from a 2D view.
  (arr gpu.view.row :
    (gpu.view val) ->
    (gpu.view val))

  # Project the column coordinate from a 2D view.
  (arr gpu.view.col :
    (gpu.view val) ->
    (gpu.view val))

  # Global memory access through a logical view. The view must match the
  # accessed memory shape, or be explicitly converted by a view operation.
  # For example, a row-major global layout maps (row, col) to row * cols + col.
  (arr gpu.global.store :
    {([matrix] val) (gpu.view val) (f32 val)} ->
    ([matrix . matrix] val))

  (arr gpu.global.load :
    {([matrix] val) (gpu.view val)} ->
    ([matrix.] (f32 val)))

  # Shared memory is block-local. When given a grid worker view, access uses
  # the worker's thread position and ignores the block position.
  (arr gpu.shared.load :
    {([tile] val) (gpu.view val)} ->
    ([tile.] (f32 val)))

  (arr gpu.shared.store :
    {([tile] val) (gpu.view val) (f32 val)} ->
    ([tile . tile] val))
})
