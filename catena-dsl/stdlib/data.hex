# basic datatypes
(theory type nat { 
  # booleans
  (arr bool : 0 -> 1)
})

(theory program type {
  # Boolean operations
  (arr bool.not : bool -> bool)
  (arr bool.or  : {bool bool} -> bool)
  (arr bool.and : {bool bool} -> bool)

  # execute one of two functions depending on a boolean flag
  #
  #   if : 2 ● (A => B) ● (A => B) -> (A => B)
  (arr bool.if : {bool =>} -> =>)
})
